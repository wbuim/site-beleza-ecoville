<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Área da Manicure | Beleza Ecoville</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>body { background: #f4f6f9; }</style>
</head>
<body>
    <div class="container py-5 max-w-md">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4>Olá, <%= nome %>!</h4>
            <a href="/logout" class="btn btn-sm btn-outline-danger">Sair</a>
        </div>

        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body text-center p-4">
                <h5 class="mb-3">Enviar Alicates para Autoclave</h5>
                <form action="/manicure/enviar" method="POST">
                    <input type="number" name="quantidade" class="form-control form-control-lg text-center mb-3" placeholder="Quantos alicates?" required min="1">
                    <button type="submit" class="btn btn-primary w-100 btn-lg">Registrar Envio</button>
                </form>
            </div>
        </div>

        <h6 class="text-muted">Seu Histórico Recente</h6>
        <ul class="list-group shadow-sm">
            <% registros.reverse().forEach(r => { %>
                <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong><%= r.quantidade %> unid.</strong><br>
                            <small class="text-muted"><%= r.data_envio %></small>
                            <% if(r.edit_count > 0) { %>
                                <br><small class="text-info" style="font-size: 0.75rem;"><i class="bi bi-pencil-square"></i> Editado <%= r.edit_count %>x</small>
                            <% } %>
                        </div>
                        
                        <div class="text-end">
                            <% if(r.status === 'Pendente') { %>
                                <span class="badge bg-warning text-dark">Aguardando Estoque</span>
                                
                                <% if((r.edit_count || 0) < 2) { %>
                                    <button class="btn btn-sm btn-light border ms-1" data-bs-toggle="collapse" data-bs-target="#edit-<%= r.id %>">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                <% } %>
                                
                            <% } else if(r.status === 'Aprovado') { %>
                                <span class="badge bg-primary">Na Autoclave</span>
                            <% } else { %>
                                <span class="badge bg-success">Devolvido (Concluído)</span>
                            <% } %>
                        </div>
                    </div>

                    <% if(r.status === 'Pendente' && (r.edit_count || 0) < 2) { %>
                        <div class="collapse mt-3 pt-3 border-top" id="edit-<%= r.id %>">
                            <form action="/manicure/editar" method="POST" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="id" value="<%= r.id %>">
                                <label class="small text-muted mb-0 text-nowrap">Corrigir para:</label>
                                <input type="number" name="nova_quantidade" class="form-control form-control-sm" value="<%= r.quantidade %>" required min="1">
                                <button type="submit" class="btn btn-success btn-sm">Salvar</button>
                            </form>
                            <small class="text-muted" style="font-size: 0.7rem;">Você pode alterar mais <%= 2 - (r.edit_count || 0) %> vez(es).</small>
                        </div>
                    <% } %>
                </li>
            <% }) %>
            
            <% if(registros.length === 0) { %>
                <li class="list-group-item text-muted text-center">Nenhum envio registrado.</li>
            <% } %>
        </ul>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>