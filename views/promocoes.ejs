<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"> 
    <title>Promoções Especiais | Beleza Ecoville</title>
    
    <link rel="icon" type="image/png" href="/images/logo-icon.png">
    <link rel="apple-touch-icon" href="/images/logo-icon.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4A3B32">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="promocoes-page">

    <a href="/" class="btn-voltar-promo"><i class="bi bi-chevron-left"></i> Voltar</a>

    <div class="container py-5">
        
        <div class="promo-header text-center mb-5">
            <img src="/images/logo.png" alt="Beleza Ecoville" height="80" class="mb-3 logo-invertida">
            <h1 class="titulo-dourado">PROMOÇÕES DO MÊS</h1>
            <p class="text-light opacity-75">Escolha sua oferta e clique no botão para agendar!</p>
        </div>

        <div class="promo-content-box">
            <div class="row justify-content-center gy-5">
                
                <% if (dados.length === 0) { %>
                    <div class="col-12 text-center">
                        <h4 class="text-muted">Nenhuma promoção ativa no momento.</h4>
                        <p>Fique de olho em nossas redes sociais!</p>
                    </div>
                <% } %>

                <% dados.forEach(promo => { %>
                    <div class="col-md-6 col-lg-5">
                        <div class="promo-card-vertical">
                            <img src="/images/promos/<%= promo.img %>?v=<%= Date.now() %>" 
                                 onerror="this.src='https://via.placeholder.com/600x900?text=Sem+Foto'" 
                                 alt="Promoção" class="img-fluid rounded-4 shadow mb-4">
                            
                            <a href="https://wa.me/5541995469023?text=<%= encodeURIComponent(promo.msg) %>" 
                               class="btn btn-verde-promo w-100 rounded-pill py-2" target="_blank">
                                <i class="bi bi-whatsapp me-2"></i> Quero agendar
                            </a>
                        </div>
                    </div>
                <% }) %>

            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>